PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tradex_auth
DB_USER=postgres
DB_PASSWORD=your_database_password

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=24h
JWT_REMEMBER_EXPIRES_IN=30d

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@tradex.com

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Security
CSRF_SECRET=your_csrf_secret_key_here
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_encryption_key_here_64_chars

# Market Data APIs
# CoinGecko API (No key required - public API)
COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Finnhub API (Required for stocks - 60 calls/min, real-time data)
# Get your free API key at: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here
FINNHUB_API_URL=https://finnhub.io/api/v1

# Fixer.io API (Optional for forex - 100 calls/month, hourly updates)
# Get your free API key at: https://fixer.io/signup/free
FIXER_API_KEY=your_fixer_api_key_here
FIXER_API_URL=http://data.fixer.io/api

# Metals-API (Optional for commodities - 50 calls/month, real-time data)
# Get your free API key at: https://metals-api.com/signup/free
METALS_API_KEY=your_metals_api_key_here
METALS_API_URL=https://metals-api.com/api
